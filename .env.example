# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# TMDB_API_KEY: Required for The Movie Database (TMDB) API calls.
TMDB_API_KEY=MY_TMDB_API_KEY

# ANILIST_CLIENT_ID: Required for AnilList GraphQL API calls.
ANILIST_CLIENT_ID=MY_ANILIST_CLIENT_ID

# ANILIST_CLIENT_SECRET: Required for AnilList GraphQL API calls.
ANILIST_CLIENT_SECRET=MY_ANILIST_CLIENT_SECRET

# JIKAN_API_URL: Public API URL for Jikan.
JIKAN_API_URL=https://api.jikan.moe/v4

# SUPABASE_URL: URL for Supabase Backend.
SUPABASE_URL=MY_SUPABASE_URL

# SUPABASE_KEY: Anon key for Supabase Backend.
SUPABASE_KEY=MY_SUPABASE_KEY

# LOOPA_CLIENT_KEY: Shared secret key for client-proxy authentication.
LOOPA_CLIENT_KEY=MY_LOOPA_CLIENT_KEY

# Android Signing Credentials
RELEASE_STORE_PASSWORD=MY_RELEASE_STORE_PASSWORD
RELEASE_KEY_PASSWORD=MY_RELEASE_KEY_PASSWORD

